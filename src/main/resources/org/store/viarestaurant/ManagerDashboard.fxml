<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ListView?>
<?import java.lang.String?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.Pane?>
<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="app-shell" xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.store.viarestaurant.viewModel.NavigationController">
    <left>
        <VBox prefWidth="220.0" spacing="18.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24.0" left="18.0" right="18.0" top="24.0"/>
            </padding>
            <children>
                <Label styleClass="brand-title" text="Via Restaurant"/>
                <VBox spacing="4.0" styleClass="sidebar-user-card">
                    <children>
                        <Label fx:id="sidebarName" styleClass="sidebar-name" text="Manager User"/>
                        <Label fx:id="sidebarRole" styleClass="sidebar-role" text="Manager"/>
                    </children>
                </VBox>
                <Separator/>
                <Button maxWidth="Infinity" fx:id="btnMenu" onAction="#showMenuPage" styleClass="nav-btn" text="Menu" />
                <Button maxWidth="Infinity" fx:id="btnReservations" onAction="#showReservationsPage" styleClass="nav-btn" text="Reservation"/>
                <Button maxWidth="Infinity" fx:id="btnTables" onAction="#showTablesPage" styleClass="nav-btn" text="Tables"/>
                <Button maxWidth="Infinity" fx:id="btnWorkers" onAction="#showWorkersPage" styleClass="nav-btn" text="Workers"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Label styleClass="sidebar-footer" text="Menu Control"/>
                <Button fx:id="logOutButton" mnemonicParsing="false" prefHeight="25.0" onAction="#handleLogOut"
                        prefWidth="184.0" style="-fx-background-color: red;" text="Log Out" textFill="WHITE"/>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane styleClass="content-area">
            <children>
                <AnchorPane styleClass="page-surface">
                    <children>
                        <VBox spacing="18.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0"
                              AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="page-title" text="Menu"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="+ New Dish" onAction="#openNewDishModal">
                                            <styleClass>
                                                <String fx:value="btn-base"/>
                                                <String fx:value="btn-primary"/>
                                            </styleClass>
                                        </Button>
                                    </children>
                                </HBox>
                                <TableView fx:id="menuTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="360.0" />
                                        <TableColumn fx:id="typeColumn" text="Type" prefWidth="220.0" />
                                        <TableColumn fx:id="priceColumn" text="Price" prefWidth="160.0" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
                <StackPane fx:id="newDishOverlay" managed="false" onMouseClicked="#closeNewDishModal" styleClass="modal-overlay" visible="false">
                    <children>
                        <VBox maxWidth="440.0" maxHeight="420.0" onMouseClicked="#consumeModalClick" spacing="14.0">
                            <styleClass>
                                <String fx:value="modal-card"/>
                                <String fx:value="modal-card-large"/>
                            </styleClass>
                            <children>
                                <Label styleClass="modal-title" text="New Dish" />

                                <TextField fx:id="dishNameField" promptText="Dish name" styleClass="input-field" />

                                <HBox spacing="12.0">
                                    <children>
                                        <ComboBox fx:id="dishTypeComboBox" prefWidth="180.0" promptText="Menu type" HBox.hgrow="ALWAYS" />
                                        <TextField fx:id="dishPriceField" promptText="Price" styleClass="input-field" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <CheckBox fx:id="isVegetarianCheckBox" text="Vegetarian" />

                                <Label text="Allergies"/>
                                <ListView fx:id="allergiesListView" prefHeight="120.0" />

                                <Label fx:id="newDishErrorLabel" managed="false" styleClass="error-label" visible="false" wrapText="true" />

                                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Button onAction="#closeNewDishModalAction" text="Cancel">
                                            <styleClass>
                                                <String fx:value="btn-base"/>
                                                <String fx:value="btn-danger"/>
                                            </styleClass>
                                        </Button>
                                        <Button onAction="#createDish" text="Create">
                                            <styleClass>
                                                <String fx:value="btn-base"/>
                                                <String fx:value="btn-primary"/>
                                            </styleClass>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
                <AnchorPane fx:id="reservationsPage" managed="false" styleClass="page-surface" visible="false">
                    <children>
                        <VBox spacing="16.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0"
                              AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="page-title" text="Reservations"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="reservationsDateLabel" styleClass="page-subtitle"
                                               text="2026-05-01"/>
                                    </children>
                                </HBox>
                                <ScrollPane fitToHeight="true" pannable="true" styleClass="plain-scroll">
                                    <content>
                                        <StackPane alignment="TOP_LEFT">
                                            <children>
                                                <GridPane fx:id="reservationGrid"/>
                                                <Pane fx:id="reservationOverlayPane" mouseTransparent="true"
                                                      pickOnBounds="false"/>
                                            </children>
                                        </StackPane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </children>
        </StackPane>
    </center>
</BorderPane>